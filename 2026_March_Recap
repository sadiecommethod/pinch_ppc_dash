            <td class="right"><span class="kpi-delta delta-up">↑ +3.2%</span></td>
          </tr>
          <tr>
            <td class="bold">ADR</td>
            <td class="right">$653</td>
            <td class="right">$594</td>
            <td class="right"><span class="kpi-delta delta-up">↑ +9.9%</span></td>
            <td class="right">$527</td>
            <td class="right"><span class="kpi-delta delta-up">↑ +3.2%</span></td>
          </tr>
          <tr>
            <td class="bold">RevPAR</td>
            <td class="right">$571</td>
            <td class="right">$526</td>
            <td class="right"><span class="kpi-delta delta-up">↑ +8.6%</span></td>
            <td class="right">$401</td>
            <td class="right"><span class="kpi-delta delta-up">↑ +6.6%</span></td>
          </tr>
          <tr>
            <td class="bold">RevPAR Index (RGI)</td>
            <td class="right">142.4</td>
            <td class="right">139.8</td>
            <td class="right"><span class="kpi-delta delta-up">↑ +2.6 pts</span></td>

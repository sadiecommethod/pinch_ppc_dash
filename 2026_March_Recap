            <td class="right"><span class="delta-up">+$33,033</span></td>
          </tr>
          <tr>
            <td class="bold">TRRTLFLEX</td>
            <td class="right">138</td>
            <td class="right">$780</td>
            <td class="right bold">$107,685</td>
            <td class="right">24.3%</td>
            <td class="right"><span class="delta-down">−40</span></td>
            <td class="right"><span class="delta-down">−$13,611</span></td>
          </tr>
          <tr class="highlight-row">
            <td class="bold">TROTAFLEX <span class="badge badge-green">↑ Winner</span></td>
            <td class="right">102</td>
            <td class="right">$544</td>
            <td class="right bold">$55,528</td>
            <td class="right">12.5%</td>
            <td class="right"><span class="delta-up">+40</span></td>
            <td class="right"><span class="delta-up">+$16,909</span></td>
          </tr>
          <tr>
            <td class="bold">TROTANREF</td>
            <td class="right">97</td>
            <td class="right">$498</td>
            <td class="right bold">$48,315</td>
            <td class="right">10.9%</td>
            <td class="right"><span class="delta-down">−19</span></td>
            <td class="right"><span class="delta-down">−$5,902</span></td>
          </tr>
          <tr>
            <td class="bold">TR LUXCONS</td>
